{
  "build": {
    "beforeDevCommand": "bun run dev:frontend",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/web-agent-sidecar"
    ],
    "resources": [
      "resources/web-agent-browser/**/*",
      "resources/web-agent-browser-manifest.json"
    ],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "tauri-app",
  "mainBinaryName": "tauri-app",
  "version": "0.1.0",
  "identifier": "com.tauri.app",
  "plugins": {},
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "SpeedAI",
        "width": 420,
        "height": 360,
        "minWidth": 420,
        "minHeight": 360,
        "center": true,
        "alwaysOnTop": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "useHttpsScheme": true
      }
    ]
  }
}
